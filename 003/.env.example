# Python Agent 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# API 认证令牌
ANTHROPIC_AUTH_TOKEN=xxxx

# API 基础 URL
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# 使用的模型
ANTHROPIC_MODEL=deepseek-v4-pro

# 思考模式强度：high（普通任务）或 max（复杂 Agent 任务，默认）
THINKING_EFFORT=max

# 模型最大输出 token 数（含思维链+回答）
MAX_TOKENS=8000

# API 超时时间（毫秒）
API_TIMEOUT_MS=3000000

# 禁用非必要流量
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
